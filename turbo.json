{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate-tokens": {
      "dependsOn": [],
      "outputs": ["apps/web/src/app/tokens.css"]
    },
    "build": {
      "dependsOn": ["^build", "generate-tokens"],
      "outputs": ["dist/**", ".next/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
